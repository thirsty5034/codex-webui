# Required: access key for WebUI API/WebSocket authentication
WEBUI_API_KEY=change-me-to-a-random-secret

# Optional: backend listen port (default 8172)
PORT=8172

# Optional: model provider API keys (at least one required for Codex to work)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: path to codex CLI binary (default: codex)
# CODEX_BIN=codex

# Optional: codex home directory (default: ~/.codex)
# CODEX_HOME=/codex-home

# Optional: comma-separated allowed workspace directories
# WORKSPACE_ROOTS=/workspaces

# Optional: SQLite database path (default: CODEX_HOME/codex-webui.sqlite)
# WEBUI_DB_PATH=

# Optional: max upload file size in bytes (default: 104857600 = 100MB)
# WEBUI_UPLOAD_MAX_BYTES=104857600

# Optional: default terminal working directory (fail-fast if invalid)
# DEFAULT_TERMINAL_CWD=

# Optional: max concurrent terminal sessions (default: 10, range: 1-50)
# WEBUI_TERMINAL_MAX_SESSIONS=10

# Optional: grace period (ms) before killing detached terminals (default: 45000, range: 10000-300000)
# WEBUI_TERMINAL_GRACE_MS=45000

# Optional: terminal scrollback buffer lines (default: 5000, range: 100-50000)
# WEBUI_TERMINAL_SCROLLBACK=5000
